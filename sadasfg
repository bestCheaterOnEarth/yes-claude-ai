                function library:Viewport(options) 
                    local cfg = {
                        item = options.item or Instance.new('Part'),
                        size = options.size or dim2(1,0,0,100),
                        distance = options.distance or 5,
                        backgroundtransparency = options.backgroundtransparency or 0,
                        child = item,
                        callback = options.callback or function() end,
                    }
                    
                    local cam = Instance.new('Camera')
                    cam.Name = ''

                    local viewport = library:create('ViewportFrame', {
                        AnchorPoint = vec2(1, 0);
                        Parent = self.elements;
                        Position = dim2(1, 0, 0, 0);
                        Size = cfg.size;
                        BorderSizePixel = 0;
                        CurrentCamera = cam;
                        BackgroundTransparency = cfg.backgroundtransparency;
                        BackgroundColor3 = rgb(255,255,255);
                    })

                    cam.Parent = viewport

                    cfg.item.Parent = viewport
                    cfg.item.Name = 'victim'

                    function update()
                        local target = cfg.item

                        if target and target:IsA('Model') then
                            target = target.PrimaryPart or target:FindFirstChildOfClass('BasePart')
                        end

                        if target and target:IsA('BasePart') then
                            local pos = target.Position
                            local front = target.CFrame.LookVector
                            local position = pos - front * -cfg.distance
                            cam.CFrame = CFrame.new(position, pos)
                        end
                    end

                    update()

                    function cfg:Set(item)
                        if viewport:FindFirstChild('victim') then
                            viewport['victim']:Destroy()
                        end
                        item.Parent = viewport
                        item.Name = 'victim'
                        cfg.item = item
                        cfg.child = item
                        update()
                    end

                    function cfg:Destroy()
                        viewport:Destory()
                    end
                    
                    return setmetatable(cfg, library)
                end

