                                if mode == 'Linear' then
                                    return t
                                elseif mode == 'Cubic' then
                                    return t < 0.5 and 4 * t * t * t or 1 - (-2 * t + 2) ^ 3 / 2
                                elseif mode == 'Quart' then
                                    return t < 0.5 and 8 * t * t * t * t or 1 - (-2 * t + 2) ^ 4 / 2
                                elseif mode == 'Quint' then
                                    return t < 0.5 and 16 * t * t * t * t * t or 1 - (-2 * t + 2) ^ 5 / 2
                                elseif mode == 'Sine' then
                                    return -(math.cos(math.pi * t) - 1) / 2
                                elseif mode == 'Expo' then
                                    return t == 0 and 0 or t == 1 and 1 or t < 0.5 and 2 ^ (20 * t - 10) / 2 or (2 - 2 ^ (-20 * t + 10)) / 2
                                elseif mode == 'Circ' then
                                    return t < 0.5 and (1 - math.sqrt(1 - (2 * t) ^ 2)) / 2 or (math.sqrt(1 - (-2 * t + 2) ^ 2) + 1) / 2
                                elseif mode == 'Back' then
