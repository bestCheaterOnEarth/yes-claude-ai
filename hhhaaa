function library:list(opts)
    local cfg = {
        name     = opts.name     or nil,
        flag     = opts.flag     or "flag",
        items    = opts.items    or {},
        scale    = opts.size     or 90,
        callback = opts.callback or function() end,
        option_instances = {},
        current_instance = nil,
        count    = self.count,
    }

    local acc_col = themes.preset[tostring(((self.count - 1) % 3) + 1)]

    local outer = New("Frame", {
        Parent           = self.elements,
        Size             = dim2(1, 0, 0, cfg.scale),
        BackgroundColor3 = acc_col,
        BorderSizePixel  = 0,
    })
    local inner = New("Frame", {
        Parent           = outer,
        Position         = dim2(0,1,0,1),
        Size             = dim2(1,-2,1,-2),
        BackgroundColor3 = rgb(35,35,35),
        BorderSizePixel  = 0,
    })
    local sf = New("ScrollingFrame", {
        Parent                  = inner,
        Size                    = dim2(1,0,1,0),
        BackgroundTransparency  = 1,
        BorderSizePixel         = 0,
        ScrollBarThickness      = 3,
        ScrollBarImageColor3    = acc_col,
        AutomaticCanvasSize     = Enum.AutomaticSize.Y,
        CanvasSize              = dim2(0,0,0,0),
        ScrollBarImageTransparency = 0.4,
    })
    New("UIListLayout", { Parent = sf, Padding = dim(0,3), SortOrder = Enum.SortOrder.LayoutOrder })
    New("UIPadding", {
        Parent = sf,
        PaddingTop = dim(0,3), PaddingBottom = dim(0,3),
        PaddingLeft = dim(0,4), PaddingRight = dim(0,4),
    })

    function cfg.refresh_options(list)
        for _, ob in cfg.option_instances do ob:Destroy() end
        cfg.option_instances = {}
        for _, item in next, list do
            local ob = New("TextButton", {
                Parent            = sf,
                Size              = dim2(1, 0, 0, 11),
                BackgroundTransparency = 1,
                FontFace          = fonts["ProggyClean"],
                TextSize          = 11,
                TextColor3        = themes.preset.text_dim,
                Text              = item,
                TextXAlignment    = Enum.TextXAlignment.Left,
                AutoButtonColor   = false,
                BorderSizePixel   = 0,
            })
            AddStroke(ob)
            insert(cfg.option_instances, ob)
            ob.MouseButton1Click:Connect(function()
                if cfg.current_instance then
                    cfg.current_instance.TextColor3 = themes.preset.text_dim
                end
                cfg.current_instance = ob
                ob.TextColor3 = themes.preset.text_white
                flags[cfg.flag] = ob.Text
                cfg.callback(ob.Text)
            end)
        end
    end

    function cfg.set(value)
        for _, ob in next, cfg.option_instances do
            ob.TextColor3 = ob.Text == value and themes.preset.text_white or themes.preset.text_dim
        end
        flags[cfg.flag] = value
        cfg.callback(value)
    end

    cfg.refresh_options(cfg.items)
    return setmetatable(cfg, library)
end

