function library:tab(props)
    local cfg = {
        name  = props.name or "tab",
        count = 0,
    }

    -- tab button
    local btn = New("TextButton", {
        Parent            = self.tab_bar,
        BackgroundTransparency = 1,
        BorderSizePixel   = 0,
        FontFace          = fonts["ProggyClean"],
        TextSize          = 12,
        TextColor3        = themes.preset.text_dim,
        Text              = cfg.name,
        AutomaticSize     = Enum.AutomaticSize.None,
    })
    AddStroke(btn)

    -- page frame
    local page = New("Frame", {
        Parent           = self.content,
        Size             = dim2(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
        Visible          = false,
    })
    New("UIListLayout", {
        Parent            = page,
        FillDirection     = Enum.FillDirection.Horizontal,
        HorizontalFlex    = Enum.UIFlexAlignment.Fill,
        VerticalFlex      = Enum.UIFlexAlignment.Fill,
        SortOrder         = Enum.SortOrder.LayoutOrder,
        Padding           = dim(0, 2),
    })
    New("UIPadding", {
        Parent        = page,
        PaddingLeft   = dim(0, 2),
        PaddingRight  = dim(0, 2),
        PaddingTop    = dim(0, 2),
        PaddingBottom = dim(0, 2),
    })
    cfg.page = page

    function cfg.open()
        local st = self.selected_tab
        if st then
            st[1].Visible     = false
            st[2].TextColor3  = themes.preset.text_dim
        end
        page.Visible      = true
        btn.TextColor3    = themes.preset.text_white
        self.selected_tab = { page, btn }
    end

    btn.MouseButton1Click:Connect(cfg.open)

    if not self.selected_tab then
        cfg.open()
    end

    return setmetatable(cfg, library)
end

