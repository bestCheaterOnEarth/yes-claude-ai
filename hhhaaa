function library:keybind(opts)
    local cfg = {
        name      = opts.name     or "Keybind",
        flag      = opts.flag     or opts.name or "flag",
        key       = opts.key      or nil,
        mode      = opts.mode     or "Toggle",
        active    = opts.default  or false,
        callback  = opts.callback or function() end,
        count     = self.count,
        open      = false,
        binding   = nil,
        hold_instances = {},
    }
    flags[cfg.flag] = {}

    local acc_col = themes.preset[tostring(((self.count - 1) % 3) + 1)]

    local row = New("Frame", {
        Parent              = self.elements,
        Size                = dim2(1, 0, 0, 14),
        BackgroundTransparency = 1,
        BorderSizePixel     = 0,
    })

    local title_lbl = New("TextLabel", {
        Parent            = row,
        Size              = dim2(0.5, 0, 1, 0),
        Position          = dim2(0, 1, 0, 0),
        BackgroundTransparency = 1,
        FontFace          = fonts["ProggyClean"],
        TextSize          = 12,
        TextColor3        = themes.preset.text,
        Text              = cfg.name,
        TextXAlignment    = Enum.TextXAlignment.Left,
        BorderSizePixel   = 0,
    })
    AddStroke(title_lbl)

    local kb_outline = New("TextButton", {
        Parent           = row,
        AnchorPoint      = vec2(1, 0),
        Position         = dim2(1, 0, 0, 0),
        Size             = dim2(0.5, 0, 1, 0),
        BackgroundColor3 = acc_col,
        Text             = "",
        AutoButtonColor  = false,
        BorderSizePixel  = 0,
    })
    local kb_inner = New("Frame", {
        Parent           = kb_outline,
        Position         = dim2(0, 1, 0, 1),
        Size             = dim2(1, -2, 1, -2),
        BackgroundColor3 = rgb(35,35,35),
        BorderSizePixel  = 0,
    })
    local key_lbl = New("TextLabel", {
        Parent            = kb_inner,
        Size              = dim2(1, 0, 1, 0),
        BackgroundTransparency = 1,
        FontFace          = fonts["ProggyClean"],
        TextSize          = 11,
        TextColor3        = themes.preset.text,
        Text              = "[ ... ]",
        BorderSizePixel   = 0,
    })
    AddStroke(key_lbl)

    -- mode popup
    local popup = New("Frame", {
        Parent           = library.gui,
        Visible          = false,
        Size             = dim2(0, 80, 0, 20),
        AutomaticSize    = Enum.AutomaticSize.Y,
        BackgroundColor3 = acc_col,
        BorderSizePixel  = 0,
        ZIndex           = 10,
    })
    local popup_inner = New("Frame", {
        Parent           = popup,
        Position         = dim2(0, 1, 0, 1),
        Size             = dim2(1, -2, 1, -2),
        AutomaticSize    = Enum.AutomaticSize.Y,
        BackgroundColor3 = themes.preset.inline,
        BorderSizePixel  = 0,
        ZIndex           = 10,
    })
    New("UIListLayout", { Parent = popup_inner, Padding = dim(0, 3), SortOrder = Enum.SortOrder.LayoutOrder })
    New("UIPadding", {
        Parent = popup_inner,
        PaddingTop = dim(0, 4), PaddingBottom = dim(0, 4),
        PaddingLeft = dim(0, 5), PaddingRight = dim(0, 5),
    })

    for _, mode_name in next, {"Hold", "Toggle", "Always"} do
        local ob = New("TextButton", {
            Parent            = popup_inner,
            Size              = dim2(1, 0, 0, 11),
            BackgroundTransparency = 1,
            FontFace          = fonts["ProggyClean"],
            TextSize          = 11,
            TextColor3        = themes.preset.text_dim,
            Text              = mode_name,
            TextXAlignment    = Enum.TextXAlignment.Left,
            AutoButtonColor   = false,
            BorderSizePixel   = 0,
            ZIndex            = 11,
        })
        AddStroke(ob)
        cfg.hold_instances[mode_name] = ob
        ob.MouseButton1Click:Connect(function()
            cfg.set(mode_name)
            popup.Visible = false
            cfg.open = false
        end)
    end

    function cfg.set_visible(bool)
        popup.Visible = bool
        if bool then
            popup.Size     = dim2(0, kb_outline.AbsoluteSize.X, 0, 20)
            popup.Position = dim_offset(
                kb_outline.AbsolutePosition.X,
                kb_outline.AbsolutePosition.Y + kb_outline.AbsoluteSize.Y + 2
            )
        end
    end

    function cfg.update_key_label()
        local k = cfg.key
        if not k or tostring(k) == "Enums" then
            key_lbl.Text = "[ ... ]"
            return
        end
        local raw = key_names[k] or tostring(k):gsub("Enum%.KeyCode%.", ""):gsub("Enum%.UserInputType%.", "")
        key_lbl.Text = "[ " .. raw .. " ]"
    end

    function cfg.set(input)
        if type(input) == "boolean" then
            cfg.active = (cfg.mode == "Always") and true or input
            cfg.callback(cfg.active)
        elseif type(input) == "string" and find({"Hold","Toggle","Always"}, input) then
            cfg.mode = input
            if input == "Always" then cfg.active = true end
            for n, ob in cfg.hold_instances do
                ob.TextColor3 = (n == input) and themes.preset.text_white or themes.preset.text_dim
            end
            cfg.callback(cfg.active)
        elseif type(input) == "table" then
            if input.key then
                if type(input.key) == "string" and input.key ~= "..." then
                    input.key = library:convert_enum(input.key)
                end
                cfg.key = (input.key == Enum.KeyCode.Escape) and nil or input.key
            end
            if input.mode then cfg.set(input.mode) end
            if input.active ~= nil then cfg.active = input.active end
        elseif tostring(input):find("Enum") then
            cfg.key = (input.Name == "Escape") and nil or input
        end
        flags[cfg.flag] = { mode = cfg.mode, key = cfg.key, active = cfg.active }
        cfg.update_key_label()
    end

    cfg.set({ mode = cfg.mode, active = cfg.active, key = cfg.key })
    config_flags[cfg.flag] = cfg.set

    kb_outline.MouseButton1Down:Connect(function()
        task.wait()
        key_lbl.Text = "..."
        if cfg.binding then cfg.binding:Disconnect() end
        cfg.binding = library:connection(uis.InputBegan, function(i, ge)
            if not ge then
                cfg.set(i.KeyCode ~= Enum.KeyCode.Unknown and i.KeyCode or i.UserInputType)
                cfg.binding:Disconnect()
                cfg.binding = nil
            end
        end)
    end)

    kb_outline.MouseButton2Down:Connect(function()
        cfg.open = not cfg.open
        cfg.set_visible(cfg.open)
    end)

    library:connection(uis.InputBegan, function(i, ge)
        if ge then return end
        if i.KeyCode == cfg.key then
            if cfg.mode == "Toggle" then
                cfg.set(not cfg.active)
            elseif cfg.mode == "Hold" then
                cfg.set(true)
            end
        end
    end)

    library:connection(uis.InputEnded, function(i, ge)
        if ge then return end
        local k = i.UserInputType == Enum.UserInputType.Keyboard and i.KeyCode or i.UserInputType
        if k == cfg.key and cfg.mode == "Hold" then cfg.set(false) end
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            if not (library:mouse_in_frame(kb_outline) or library:mouse_in_frame(popup)) then
                cfg.open = false
                cfg.set_visible(false)
            end
        end
    end)

    return setmetatable(cfg, library)
end

