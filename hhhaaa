library.sgui = New("ScreenGui", {
    Name   = "priv9_overlay",
    Parent = gethui(),
})

local watermark_obj = {}

function library:watermark(options)
    local name = options.name or "priv9"

    local outline = New("Frame", {
        Parent           = library.sgui,
        Position         = dim2(0, 8, 0, 8),
        Size             = dim2(0, 0, 0, 22),
        AutomaticSize    = Enum.AutomaticSize.X,
        BackgroundColor3 = rgb(255,255,255),
        BorderSizePixel  = 0,
    })
    GradientBar(outline)
    library:draggify(outline)

    local inner = New("Frame", {
        Parent              = outline,
        Position            = dim2(0, 1, 0, 1),
        Size                = dim2(1, -2, 1, -2),
        BackgroundColor3    = themes.preset.background,
        BackgroundTransparency = 0,
        BorderSizePixel     = 0,
    })

    New("UIPadding", {
        Parent        = inner,
        PaddingLeft   = dim(0, 5),
        PaddingRight  = dim(0, 5),
        PaddingTop    = dim(0, 4),
        PaddingBottom = dim(0, 4),
    })

    local label = New("TextLabel", {
        Parent            = inner,
        Size              = dim2(0, 0, 1, 0),
        AutomaticSize     = Enum.AutomaticSize.X,
        BackgroundTransparency = 1,
        FontFace          = fonts["ProggyClean"],
        TextSize          = 12,
        TextColor3        = themes.preset.text_white,
        Text              = name,
        TextXAlignment    = Enum.TextXAlignment.Left,
        BorderSizePixel   = 0,
    })
    AddStroke(label)

    watermark_obj.label = label

    function watermark_obj.update(text)
        label.Text = text
    end

    -- fps / ping ticker
    local fps_count = 0
    local last_tick = tick()

    run.RenderStepped:Connect(function()
        fps_count += 1
        if tick() - last_tick >= 1 then
            last_tick = tick()
            local ping = math.floor(stats.PerformanceStats.Ping:GetValue())
            label.Text = string.format("priv9  fps: %d  ping: %dms", fps_count, ping)
            fps_count = 0
        end
    end)

    return watermark_obj
end

