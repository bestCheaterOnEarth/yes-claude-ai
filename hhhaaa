function library:textbox(opts)
    local cfg = {
        name        = opts.name        or "Input",
        flag        = opts.flag        or opts.name or "flag",
        placeholder = opts.placeholder or "type here...",
        default     = opts.default,
        callback    = opts.callback    or function() end,
    }

    local acc_col = themes.preset[tostring(((self.count - 1) % 3) + 1)]

    local frame = New("Frame", {
        Parent           = self.elements,
        Size             = dim2(1, 0, 0, 14),
        BackgroundColor3 = acc_col,
        BorderSizePixel  = 0,
    })
    local inner = New("Frame", {
        Parent           = frame,
        Position         = dim2(0, 1, 0, 1),
        Size             = dim2(1, -2, 1, -2),
        BackgroundColor3 = themes.preset.inline,
        BorderSizePixel  = 0,
    })
    local tb = New("TextBox", {
        Parent            = inner,
        Size              = dim2(1, -8, 1, 0),
        Position          = dim2(0, 4, 0, 0),
        BackgroundTransparency = 1,
        FontFace          = fonts["ProggyClean"],
        TextSize          = 12,
        TextColor3        = themes.preset.text_white,
        PlaceholderColor3 = themes.preset.text_dim,
        PlaceholderText   = cfg.placeholder,
        Text              = "",
        ClearTextOnFocus  = false,
        TextXAlignment    = Enum.TextXAlignment.Left,
        TextTruncate      = Enum.TextTruncate.AtEnd,
        BorderSizePixel   = 0,
    })
    AddStroke(tb)

    function cfg.set(text)
        flags[cfg.flag] = text
        tb.Text = text
        cfg.callback(text)
    end

    if cfg.default then cfg.set(cfg.default) end
    config_flags[cfg.flag] = cfg.set

    tb:GetPropertyChangedSignal("Text"):Connect(function()
        flags[cfg.flag] = tb.Text
        cfg.callback(tb.Text)
    end)

    return setmetatable(cfg, library)
end

