function library:init_players(window)
    local tab = window:tab({ name = "players" })

    -- full-width single column, no section wrapper
    local col = tab:column({})

    -- header labels
    local header_frame = New("Frame", {
        Parent              = col.column,
        Size                = dim2(1, 0, 0, 12),
        BackgroundTransparency = 1,
        BorderSizePixel     = 0,
    })
    local function header_lbl(text, xalign, pos_x, size_x)
        local l = New("TextLabel", {
            Parent            = header_frame,
            Size              = dim2(size_x, 0, 1, 0),
            Position          = dim2(pos_x, 0, 0, 0),
            BackgroundTransparency = 1,
            FontFace          = fonts["ProggyClean"],
            TextSize          = 11,
            TextColor3        = themes.preset.text_dim,
            Text              = text,
            TextXAlignment    = xalign,
            BorderSizePixel   = 0,
        })
        AddStroke(l)
    end
    header_lbl("index",        Enum.TextXAlignment.Left,   0,    0.1)
    header_lbl("username",     Enum.TextXAlignment.Left,   0.1,  0.35)
    header_lbl("display name", Enum.TextXAlignment.Left,   0.45, 0.35)
    header_lbl("priority",     Enum.TextXAlignment.Left,   0.8,  0.2)

    -- divider
    New("Frame", {
        Parent           = col.column,
        Size             = dim2(1, 0, 0, 1),
        BackgroundColor3 = themes.preset.outline,
        BorderSizePixel  = 0,
    })

    -- rows container
    local rows_frame = New("Frame", {
        Parent              = col.column,
        Size                = dim2(1, 0, 0, 0),
        AutomaticSize       = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        BorderSizePixel     = 0,
    })
    New("UIListLayout", {
        Parent    = rows_frame,
        Padding   = dim(0, 2),
        SortOrder = Enum.SortOrder.LayoutOrder,
    })

    local function add_player_row(idx, username, display, priority)
        local row = New("Frame", {
            Parent              = rows_frame,
            Size                = dim2(1, 0, 0, 11),
            BackgroundTransparency = 1,
            BorderSizePixel     = 0,
        })
        local function cell(text, xalign, pos_x, size_x, is_priority)
            local col3 = is_priority and (text == "Client" and themes.preset["1"] or themes.preset.text_dim) or themes.preset.text
            local l = New("TextLabel", {
                Parent            = row,
                Size              = dim2(size_x, 0, 1, 0),
                Position          = dim2(pos_x, 0, 0, 0),
                BackgroundTransparency = 1,
                FontFace          = fonts["ProggyClean"],
                TextSize          = 11,
                TextColor3        = col3,
                Text              = tostring(text),
                TextXAlignment    = xalign,
                BorderSizePixel   = 0,
            })
            AddStroke(l)
        end
        cell(idx,      Enum.TextXAlignment.Left, 0,    0.1,  false)
        cell(username, Enum.TextXAlignment.Left, 0.1,  0.35, false)
        cell(display,  Enum.TextXAlignment.Left, 0.45, 0.35, false)
        cell(priority, Enum.TextXAlignment.Left, 0.8,  0.2,  true)
    end

    -- populate current players
    local function refresh()
        for _, child in rows_frame:GetChildren() do
            if child:IsA("Frame") then child:Destroy() end
        end
        local lp_name = lp.Name
        local i = 1
        for _, p in next, players:GetPlayers() do
            local priority = p.Name == lp_name and "Client" or "None"
            add_player_row(i, p.Name, p.DisplayName, priority)
            i += 1
        end
    end

    refresh()
    players.PlayerAdded:Connect(refresh)
    players.PlayerRemoving:Connect(function() task.wait() refresh() end)

    return tab
end

