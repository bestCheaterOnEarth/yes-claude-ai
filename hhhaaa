local function New(cls, props)
    local i = Instance.new(cls)
    for k, v in next, props do
        i[k] = v
    end
    return i
end

-- thin outline stroke for text elements
local function AddStroke(parent, col)
    New("UIStroke", {
        Parent        = parent,
        Color         = col or themes.preset.outline,
        LineJoinMode  = Enum.LineJoinMode.Miter,
        Thickness     = 1,
    })
end

-- gradient bar (title / watermark / section header)
local function GradientBar(parent)
    New("UIGradient", {
        Parent = parent,
        Color  = rgbseq({
            rgbkey(0,   themes.preset["1"]),
            rgbkey(0.5, themes.preset["2"]),
            rgbkey(1,   themes.preset["3"]),
        }),
    })
end

-- ──────────────────────────────────────────────────────────
-- DRAG / RESIZE
-- ──────────────────────────────────────────────────────────

function library:draggify(frame)
    local dragging, start_pos, start_input = false
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging   = true
            start_pos  = frame.Position
            start_input= input.Position
        end
    end)
    frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    library:connection(uis.InputChanged, function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local vp = camera.ViewportSize
            frame.Position = dim2(0,
                clamp(start_pos.X.Offset + (input.Position.X - start_input.X), 0, vp.X - frame.Size.X.Offset),
                0,
                clamp(start_pos.Y.Offset + (input.Position.Y - start_input.Y), 0, vp.Y - frame.Size.Y.Offset)
            )
        end
    end)
end

function library:resizify(frame)
    local btn = New("TextButton", {
        Parent              = frame,
        Position            = dim2(1, -10, 1, -10),
        Size                = dim2(0, 10, 0, 10),
        BackgroundColor3    = rgb(255,255,255),
        BackgroundTransparency = 1,
        BorderSizePixel     = 0,
        Text                = "",
    })
    local resizing, start_size, start_pos = false
    local og = frame.Size
    btn.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing   = true
            start_size = frame.Size
            start_pos  = i.Position
        end
    end)
    btn.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then resizing = false end
    end)
    library:connection(uis.InputChanged, function(i)
        if resizing and i.UserInputType == Enum.UserInputType.MouseMovement then
            local vp = camera.ViewportSize
            frame.Size = dim2(0,
                clamp(start_size.X.Offset + (i.Position.X - start_pos.X), og.X.Offset, vp.X),
                0,
                clamp(start_size.Y.Offset + (i.Position.Y - start_pos.Y), og.Y.Offset, vp.Y)
            )
        end
    end)
end

