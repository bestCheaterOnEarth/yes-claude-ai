        Size             = dim2(1, -18, 0, 12),
        BackgroundColor3 = themes.preset.inline,
        Text             = "",
        AutoButtonColor  = false,
        BorderSizePixel  = 0,
        ZIndex           = 11,
    })
    local alpha_inner = New("Frame", {
        Parent           = alpha_btn,
        Position         = dim2(0,1,0,1),
        Size             = dim2(1,-2,1,-2),
        BackgroundColor3 = rgb(0,170,255),
        BorderSizePixel  = 0,
        ZIndex           = 11,
    })
    New("UIGradient", {
        Parent      = alpha_inner,
        Transparency= numseq({numkey(0,0), numkey(1,1)}),
    })
    local alpha_ind = New("Frame", {
        Parent           = alpha_inner,
        Size             = dim2(0,3,1,2),
        BackgroundColor3 = rgb(255,255,255),
        BorderSizePixel  = 1,
        ZIndex           = 12,
    })

    -- hex textbox
    local hex_box = New("TextBox", {
        Parent            = picker_inner,
        Position          = dim2(0, 0, 0, 101),
        Size              = dim2(1, -18, 0, 14),
        BackgroundColor3  = themes.preset.inline,
        FontFace          = fonts["ProggyClean"],
        TextSize          = 11,
        TextColor3        = themes.preset.text,
        Text              = "",
        PlaceholderText   = "r, g, b, a",
        PlaceholderColor3 = themes.preset.text_dim,
        ClearTextOnFocus  = false,
        TextXAlignment    = Enum.TextXAlignment.Center,
        BorderSizePixel   = 0,
        ZIndex            = 11,
    })
    AddStroke(hex_box)

    local h, s, v_val = cfg.color:ToHSV()
    local a_val = cfg.alpha

    function cfg.set_visible(bool)
        picker.Visible = bool
        if bool then
            picker.Position = dim_offset(
                swatch_outline.AbsolutePosition.X - 120,
                swatch_outline.AbsolutePosition.Y + swatch_outline.AbsoluteSize.Y + 2
            )
        end
    end

    function cfg.set(c, al)
        if c  then h, s, v_val = c:ToHSV() end
        if al then a_val = al end
        local col = Color3.fromHSV(h, s, v_val)
        swatch.BackgroundColor3  = col
        sv_color.BackgroundColor3= Color3.fromHSV(h, 1, 1)
        alpha_inner.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
        sv_dot.Position      = dim2(s, -2, 1 - v_val, -2)
        hue_indicator.Position = dim2(0, -1, 1 - h, -1)
        alpha_ind.Position   = dim2(1 - a_val, -1, 0, -1)
        flags[cfg.flag]      = { Color = col, Transparency = a_val }
        hex_box.Text = string.format("%d, %d, %d, %.2f",
            floor(col.R * 255), floor(col.G * 255), floor(col.B * 255), 1 - a_val)
        cfg.callback(col, a_val)
    end

    cfg.set(cfg.color, cfg.alpha)
    config_flags[cfg.flag] = cfg.set

    -- dragging
    local drag_sv, drag_hue, drag_a = false, false, false

    sv_btn.MouseButton1Down:Connect(function() drag_sv = true end)
    hue_btn.MouseButton1Down:Connect(function() drag_hue = true end)
    alpha_btn.MouseButton1Down:Connect(function() drag_a = true end)

    library:connection(uis.InputChanged, function(i)
        if not (drag_sv or drag_hue or drag_a) then return end
        if i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local pos = uis:GetMouseLocation()
        local off = vec2(pos.X, pos.Y - gui_offset)
        if drag_sv then
            s     = clamp((off - sv_btn.AbsolutePosition).X / sv_btn.AbsoluteSize.X, 0, 1)
            v_val = 1 - clamp((off - sv_btn.AbsolutePosition).Y / sv_btn.AbsoluteSize.Y, 0, 1)
        elseif drag_hue then
            h = 1 - clamp((off - hue_btn.AbsolutePosition).Y / hue_btn.AbsoluteSize.Y, 0, 1)
        elseif drag_a then
            a_val = 1 - clamp((off - alpha_btn.AbsolutePosition).X / alpha_btn.AbsoluteSize.X, 0, 1)
        end
        cfg.set(nil, nil)
    end)

    library:connection(uis.InputEnded, function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag_sv = false drag_hue = false drag_a = false
            if not (library:mouse_in_frame(row) or library:mouse_in_frame(picker)) then
                cfg.open = false
                cfg.set_visible(false)
            end
        end
    end)

    row.MouseButton1Click:Connect(function()
        cfg.open = not cfg.open
        cfg.set_visible(cfg.open)
    end)

    hex_box.FocusLost:Connect(function()
        local r, g, b, al = library:convert(hex_box.Text)
        if r and g and b and al then
            cfg.set(rgb(r, g, b), 1 - al)
        end
    end)

    return setmetatable(cfg, library)
end

