-- HELPERS
-- ──────────────────────────────────────────────────────────

function library:round(n, f)
    local m = 1 / (f or 1)
    return floor(n * m + 0.5) / m
end

function library:mouse_in_frame(obj)
    local ap = obj.AbsolutePosition
    local as = obj.AbsoluteSize
    return mouse.X >= ap.X and mouse.X <= ap.X + as.X
       and mouse.Y >= ap.Y and mouse.Y <= ap.Y + as.Y
end

function library:connection(signal, cb)
    local c = signal:Connect(cb)
    insert(library.connections, c)
    return c
end

function library:tween(obj, props, t)
    tween_service:Create(obj, TweenInfo.new(t or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

function library:convert(str)
    local v = {}
    for x in string.gmatch(str, "[^,]+") do
        insert(v, tonumber(x))
    end
    if #v == 4 then return unpack(v) end
end

function library:convert_enum(str)
    local parts = {}
    for p in string.gmatch(str, "[%w_]+") do insert(parts, p) end
    local t = Enum
    for i = 2, #parts do t = t[parts[i]] end
    return t
end

