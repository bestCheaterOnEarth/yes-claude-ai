-- ══════════════════════════════════════════════════════════

function library:slider(opts)
    local cfg = {
        name      = opts.name     or "Slider",
        flag      = opts.flag     or opts.name or "flag",
        suffix    = opts.suffix   or "",
        min       = opts.min      or 0,
        max       = opts.max      or 100,
        intervals = opts.interval or opts.decimal or 1,
        default   = opts.default  or 0,
        value     = opts.default  or 0,
        callback  = opts.callback or function() end,
        count     = self.count,
        dragging  = false,
    }

    local acc_col = themes.preset[tostring(((self.count - 1) % 3) + 1)]

    local frame = New("Frame", {
        Parent              = self.elements,
        Size                = dim2(1, 0, 0, 24),
        BackgroundTransparency = 1,
        BorderSizePixel     = 0,
    })

    local top_lbl = New("TextLabel", {
        Parent            = frame,
        Size              = dim2(1, 0, 0, 12),
        Position          = dim2(0, 0, 0, 0),
        BackgroundTransparency = 1,
        FontFace          = fonts["ProggyClean"],
        TextSize          = 12,
        TextColor3        = themes.preset.text,
        RichText          = true,
        Text              = cfg.name,
        TextXAlignment    = Enum.TextXAlignment.Left,
        BorderSizePixel   = 0,
    })
    AddStroke(top_lbl)

    local track_outline = New("TextButton", {
        Parent           = frame,
        Position         = dim2(0, 0, 0, 13),
        Size             = dim2(1, 0, 0, 11),
        BackgroundColor3 = acc_col,
        Text             = "",
        BorderSizePixel  = 0,
        AutoButtonColor  = false,
    })
    local track_inner = New("Frame", {
        Parent           = track_outline,
        Position         = dim2(0, 1, 0, 1),
        Size             = dim2(1, -2, 1, -2),
        BackgroundColor3 = themes.preset.inline,
        BorderSizePixel  = 0,
    })
    local fill = New("Frame", {
        Parent           = track_inner,
        Size             = dim2(0, 0, 1, 0),
        BackgroundColor3 = acc_col,
        BorderSizePixel  = 0,
    })

    function cfg.set(val)
        local n = tonumber(val)
        if not n then return end
        cfg.value       = clamp(library:round(n, cfg.intervals), cfg.min, cfg.max)
        flags[cfg.flag] = cfg.value
        fill.Size       = dim2((cfg.value - cfg.min) / (cfg.max - cfg.min), 0, 1, 0)
        top_lbl.Text    = cfg.name .. string.format("<font color='#888888'> - %s%s</font>", tostring(cfg.value), cfg.suffix)
        cfg.callback(cfg.value)
    end

    cfg.set(cfg.default)
    config_flags[cfg.flag] = cfg.set

    track_outline.MouseButton1Down:Connect(function() cfg.dragging = true end)
    library:connection(uis.InputChanged, function(i)
        if cfg.dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local sx = (i.Position.X - track_inner.AbsolutePosition.X) / track_inner.AbsoluteSize.X
            cfg.set(((cfg.max - cfg.min) * sx) + cfg.min)
        end
    end)
    library:connection(uis.InputEnded, function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then cfg.dragging = false end
    end)

    return setmetatable(cfg, library)
end

