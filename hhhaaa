local config_holder_ref = nil

function library:update_config_list()
    if not config_holder_ref then return end
    local list = {}
    for _, file in listfiles(library.directory .. "/configs") do
        local name = file
            :gsub(library.directory .. "/configs\\", "")
            :gsub(library.directory .. "\\configs\\", "")
            :gsub(library.directory .. "/configs/", "")
            :gsub("%.cfg$", "")
        insert(list, name)
    end
    config_holder_ref.refresh_options(list)
end

function library:get_config()
    local out = {}
    for k, v in flags do
        if type(v) == "table" and v.key then
            out[k] = { active = v.active, mode = v.mode, key = tostring(v.key) }
        elseif type(v) == "table" and v.Transparency and v.Color then
            out[k] = { Transparency = v.Transparency, Color = v.Color:ToHex() }
        else
            out[k] = v
        end
    end
    return http_service:JSONEncode(out)
end

function library:load_config(json)
    local data = http_service:JSONDecode(json)
    for k, v in next, data do
        if k == "config_name_list" then continue end
        local fn = config_flags[k]
        if fn then
            if type(v) == "table" and v.Transparency and v.Color then
                fn(hex(v.Color), v.Transparency)
            elseif type(v) == "table" and v.active ~= nil then
                fn(v)
            else
                fn(v)
            end
        end
    end
end

function library:init_config(window)
    local textbox_ref
    local tab     = window:tab({ name = "settings" })
    local col_cfg = tab:column({})
    local sec_cfg = col_cfg:section({ name = "config creation" })

    config_holder_ref = sec_cfg:dropdown({
        name     = "configs",
        items    = { "no configs found" },
        flag     = "config_name_list",
        callback = function(opt) if textbox_ref then textbox_ref.set(opt) end end,
    })
    library:update_config_list()

    textbox_ref = sec_cfg:textbox({ name = "config name:", placeholder = "type here...", flag = "config_name_text" })

    sec_cfg:button({ name = "save", callback = function()
        writefile(library.directory .. "/configs/" .. (flags["config_name_text"] or "default") .. ".cfg", library:get_config())
        library:update_config_list()
    end })
    sec_cfg:button({ name = "load", callback = function()
        local path = library.directory .. "/configs/" .. (flags["config_name_text"] or "") .. ".cfg"
        if isfile(path) then library:load_config(readfile(path)) end
    end })
    sec_cfg:button({ name = "delete", callback = function()
        local path = library.directory .. "/configs/" .. (flags["config_name_text"] or "") .. ".cfg"
        if isfile(path) then delfile(path) end
        library:update_config_list()
    end })

    local col_ui = tab:column({})
    local sec_ui = col_ui:section({ name = "ui" })

    sec_ui:keybind({
        name     = "menu bind",
        flag     = "menu_bind",
        default  = true,
        callback = function(bool) window.toggle_menu(bool) end,
    })

    sec_ui:colorpicker({
        name     = "accent",
        flag     = "accent_color",
        color    = themes.preset["1"],
        callback = function(c)
            themes.preset["1"] = c
        end,
    })

    tab:column({}) -- filler
end

