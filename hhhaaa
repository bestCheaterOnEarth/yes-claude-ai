local notif_list = {}

local function create_notif(text)
    local idx = #notif_list + 1
    local yoff = 40 + (idx - 1) * 28

    local outline = New("Frame", {
        Parent           = library.sgui,
        Position         = dim_offset(-200, yoff),
        Size             = dim2(0, 0, 0, 22),
        AutomaticSize    = Enum.AutomaticSize.X,
        BackgroundColor3 = rgb(255,255,255),
        BorderSizePixel  = 0,
    })
    GradientBar(outline)

    local inner = New("Frame", {
        Parent              = outline,
        Position            = dim2(0, 1, 0, 1),
        Size                = dim2(1, -2, 1, -2),
        BackgroundColor3    = themes.preset.background,
        BackgroundTransparency = 0.35,
        BorderSizePixel     = 0,
    })
    New("UIPadding", {
        Parent = inner,
        PaddingLeft   = dim(0, 6),
        PaddingRight  = dim(0, 6),
        PaddingTop    = dim(0, 4),
        PaddingBottom = dim(0, 4),
    })
    local lbl = New("TextLabel", {
        Parent            = inner,
        Size              = dim2(0, 0, 1, 0),
        AutomaticSize     = Enum.AutomaticSize.X,
        BackgroundTransparency = 1,
        FontFace          = fonts["ProggyClean"],
        TextSize          = 12,
        TextColor3        = themes.preset.text_white,
        Text              = text,
        TextXAlignment    = Enum.TextXAlignment.Left,
        BorderSizePixel   = 0,
    })
    AddStroke(lbl)

    insert(notif_list, outline)

    -- slide in
    tween_service:Create(outline, TweenInfo.new(0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out),
        { Position = dim_offset(8, yoff) }):Play()

    task.spawn(function()
        task.wait(3.5)
        tween_service:Create(outline, TweenInfo.new(0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.In),
            { Position = dim_offset(-200, yoff) }):Play()
        task.wait(0.5)
        outline:Destroy()
        local i = table.find(notif_list, outline)
        if i then table.remove(notif_list, i) end
    end)
end

