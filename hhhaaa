        BorderSizePixel   = 0,
    })
    AddStroke(lbl)

    -- checkbox (accent border)
    local box_outline = New("Frame", {
        Parent           = row,
        AnchorPoint      = vec2(1, 0),
        Position         = dim2(1, 0, 0, 0),
        Size             = dim2(0, 12, 0, 12),
        BackgroundColor3 = acc_col,
        BorderSizePixel  = 0,
    })
    local box_fill = New("Frame", {
        Parent           = box_outline,
        Position         = dim2(0, 1, 0, 1),
        Size             = dim2(1, -2, 1, -2),
        BackgroundColor3 = themes.preset.inline,
        BorderSizePixel  = 0,
    })

    -- fold elements
    local fold_frame
    if cfg.folding then
        fold_frame = New("Frame", {
            Parent           = self.elements,
            Size             = dim2(1, 0, 0, 0),
            AutomaticSize    = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            BorderSizePixel  = 0,
            Visible          = false,
        })
        New("UIListLayout", {
            Parent    = fold_frame,
            Padding   = dim(0, 5),
            SortOrder = Enum.SortOrder.LayoutOrder,
        })
        cfg.elements = fold_frame
    end

    function cfg.set(bool)
        cfg.enabled    = bool
        flags[cfg.flag] = bool
        box_fill.BackgroundColor3 = bool and acc_col or themes.preset.inline
        if cfg.folding and fold_frame then
            fold_frame.Visible = bool
        end
        cfg.callback(bool)
    end

    cfg.set(cfg.default)
    config_flags[cfg.flag] = cfg.set

    row.MouseButton1Click:Connect(function()
        cfg.set(not cfg.enabled)
    end)

    return setmetatable(cfg, library)
end

