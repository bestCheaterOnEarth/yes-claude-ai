        Text              = tostring(cfg.default),
        TextXAlignment    = Enum.TextXAlignment.Center,
        BorderSizePixel   = 0,
    })
    AddStroke(selected_lbl)

    -- floating popup
    local popup = New("Frame", {
        Parent           = library.gui,
        Visible          = false,
        Size             = dim2(0, 100, 0, 20),
        AutomaticSize    = Enum.AutomaticSize.Y,
        BackgroundColor3 = acc_col,
        BorderSizePixel  = 0,
        ZIndex           = 10,
    })
    local popup_inner = New("Frame", {
        Parent           = popup,
        Position         = dim2(0, 1, 0, 1),
        Size             = dim2(1, -2, 1, -2),
        AutomaticSize    = Enum.AutomaticSize.Y,
        BackgroundColor3 = themes.preset.inline,
        BorderSizePixel  = 0,
        ZIndex           = 10,
    })
    New("UIListLayout", { Parent = popup_inner, Padding = dim(0, 3), SortOrder = Enum.SortOrder.LayoutOrder })
    New("UIPadding", {
        Parent        = popup_inner,
        PaddingTop    = dim(0, 4),
        PaddingBottom = dim(0, 4),
        PaddingLeft   = dim(0, 5),
        PaddingRight  = dim(0, 5),
    })

    function cfg.set_visible(bool)
        popup.Visible = bool
        if bool then
            popup.Size = dim2(0, btn_outline.AbsoluteSize.X, 0, 20)
            popup.Position = dim_offset(
                btn_outline.AbsolutePosition.X,
                btn_outline.AbsolutePosition.Y + btn_outline.AbsoluteSize.Y + 2
            )
        end
    end

    function cfg.render_option(text)
        local ob = New("TextButton", {
            Parent            = popup_inner,
            Size              = dim2(1, 0, 0, 11),
            BackgroundTransparency = 1,
            FontFace          = fonts["ProggyClean"],
            TextSize          = 11,
            TextColor3        = themes.preset.text_dim,
            Text              = text,
            TextXAlignment    = Enum.TextXAlignment.Left,
            AutoButtonColor   = false,
            BorderSizePixel   = 0,
            ZIndex            = 11,
        })
        AddStroke(ob)
        return ob
    end

    function cfg.set(value)
        local selected = {}
        local is_table = type(value) == "table"
        for _, op in next, cfg.option_instances do
            if op.Text == value or (is_table and find(value, op.Text)) then
                insert(selected, op.Text)
                op.TextColor3 = themes.preset.text_white
                cfg.multi_items = selected
            else
                op.TextColor3 = themes.preset.text_dim
            end
        end
        selected_lbl.Text  = is_table and concat(selected, ", ") or (selected[1] or "")
        flags[cfg.flag]     = is_table and selected or selected[1]
        cfg.callback(flags[cfg.flag])
    end

    function cfg.refresh_options(list)
        for _, op in next, cfg.option_instances do op:Destroy() end
        cfg.option_instances = {}
        for _, item in next, list do
            local ob = cfg.render_option(item)
            insert(cfg.option_instances, ob)
            ob.MouseButton1Down:Connect(function()
                if cfg.multi then
                    local idx = find(cfg.multi_items, ob.Text)
                    if idx then remove(cfg.multi_items, idx)
                    else insert(cfg.multi_items, ob.Text) end
                    cfg.set(cfg.multi_items)
                else
                    cfg.set(ob.Text)
                    cfg.set_visible(false)
                    cfg.open = false
                end
            end)
        end
    end

    cfg.refresh_options(cfg.items)
    cfg.set(cfg.default)
    config_flags[cfg.flag] = cfg.set

    btn_outline.MouseButton1Click:Connect(function()
        cfg.open = not cfg.open
        cfg.set_visible(cfg.open)
    end)
    library:connection(uis.InputEnded, function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            if not (library:mouse_in_frame(popup) or library:mouse_in_frame(row)) then
                cfg.open = false
                cfg.set_visible(false)
            end
        end
    end)

    return setmetatable(cfg, library)
end

